# .env

# Токен твоего Telegram-бота

# URL прокси (SOCKS5 или HTTP), если нужен. Примеры:
# SOCKS5: socks5://login:password@proxy-server:1080
# HTTP: http://login:password@proxy-server:3128
# Если не используешь прокси, оставь пустым или закомментируй.
